---
import { getEntry } from "astro:content";
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const resume = await getEntry("resume", lang);
const phone = resume?.data.phone;
const waNumber = phone?.replace(/[^\d]/g, "");
const telNumber = phone?.replace(/\s+/g, "");
---

{
  waNumber && telNumber && (
    <div class="contact-fab">
      <div class="fab-menu">
        <a class="fab-item" href={`tel:${telNumber}`}>
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z"
            />
          </svg>
          <span class="fab-tooltip">{t("contact.call")}</span>
        </a>
        <a class="fab-item" href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 32 32" width="22" height="22" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M16.004 3C9.376 3 4 8.373 4 15c0 2.302.646 4.454 1.766 6.287L4 29l7.9-1.727A11.94 11.94 0 0 0 16.004 27C22.63 27 28 21.627 28 15S22.63 3 16.004 3Zm6.996 16.845c-.297.836-1.47 1.53-2.41 1.73-.66.14-1.52.252-4.41-.945-3.7-1.532-6.08-5.263-6.267-5.508-.18-.245-1.5-1.997-1.5-3.81s.94-2.7 1.28-3.07c.297-.32.65-.4.867-.4.216 0 .434.002.624.012.213.01.487-.08.762.582.297.71 1.007 2.454 1.096 2.633.09.18.15.39.03.635-.12.245-.18.398-.36.61-.18.21-.375.472-.535.634-.18.18-.367.375-.157.735.21.36.933 1.542 2.003 2.497 1.377 1.23 2.54 1.61 2.9 1.79.36.18.57.15.78-.09.21-.24.9-1.05 1.14-1.41.24-.36.48-.3.81-.18.33.12 2.1.99 2.46 1.17.36.18.6.27.69.42.09.15.09.868-.207 1.705Z"
            />
          </svg>
          <span class="fab-tooltip">{t("contact.callWhatsapp")}</span>
        </a>
        <a class="fab-item" href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" focusable="false">
            <path
              fill="currentColor"
              d="M12 2C6.477 2 2 6.03 2 11c0 2.29 1.02 4.36 2.7 5.94-.19 1.4-.7 2.94-1.5 4.06 1.68-.2 3.4-.77 4.66-1.5A11.4 11.4 0 0 0 12 20c5.523 0 10-4.03 10-9s-4.477-9-10-9Z"
            />
          </svg>
          <span class="fab-tooltip">{t("contact.chatWhatsapp")}</span>
        </a>
      </div>

      <button
        type="button"
        class="fab-main"
        aria-haspopup="true"
        aria-expanded="false"
        aria-label={t("contact.menuLabel")}
      >
        <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M12 2C6.48 2 2 6.03 2 11c0 2.42 1.06 4.6 2.77 6.19L4 22l4.94-1.32A11.6 11.6 0 0 0 12 21c5.52 0 10-4.03 10-10S17.52 2 12 2Z"
          />
          <circle cx="7.8" cy="11" r="1.35" fill="var(--bg)" />
          <circle cx="12" cy="11" r="1.35" fill="var(--bg)" />
          <circle cx="16.2" cy="11" r="1.35" fill="var(--bg)" />
        </svg>
      </button>
    </div>
  )
}

<script src="/scripts/contact-fab.js" is:inline defer></script>

<style>
  .contact-fab {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 20;
  }
  .fab-main {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--accent);
    color: var(--bg);
    border: none;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.4);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }
  .fab-main:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.5);
  }
  .fab-menu {
    position: absolute;
    bottom: 100%;
    right: 4px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
    margin-bottom: 16px;
  }
  .fab-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--bg-raised);
    border: 1px solid var(--border);
    color: var(--text);
    opacity: 0;
    visibility: hidden;
    transform: translateY(14px) scale(0.5);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      visibility 0s linear 0.25s;
  }
  .contact-fab:hover .fab-item,
  .contact-fab.open .fab-item {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      visibility 0s linear 0s;
  }
  /* Reveal cascades outward from the button: the item closest to it
     (last in DOM order, since flex-direction: column stacks downward)
     animates in first, the furthest one last. */
  .contact-fab:hover .fab-item:nth-last-child(1),
  .contact-fab.open .fab-item:nth-last-child(1) {
    transition-delay: 0s;
  }
  .contact-fab:hover .fab-item:nth-last-child(2),
  .contact-fab.open .fab-item:nth-last-child(2) {
    transition-delay: 0.06s;
  }
  .contact-fab:hover .fab-item:nth-last-child(3),
  .contact-fab.open .fab-item:nth-last-child(3) {
    transition-delay: 0.12s;
  }
  .fab-item:hover,
  .fab-item:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
  }
  .fab-tooltip {
    /* A real (if visually detached) part of the same link, not a
       decorative overlay — deliberately left clickable/hoverable so
       the text is as much of a target as the icon. */
    position: absolute;
    right: calc(100% + 12px);
    top: 50%;
    transform: translateY(-50%);
    background: var(--bg-raised);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 6px 10px;
    border-radius: var(--radius);
    white-space: nowrap;
  }
  .fab-item:hover .fab-tooltip,
  .fab-item:focus-visible .fab-tooltip {
    border-color: var(--accent);
    color: var(--accent);
  }
  [dir="rtl"] .fab-tooltip {
    right: auto;
    left: calc(100% + 12px);
  }
  @media (max-width: 480px) {
    .contact-fab {
      right: 16px;
      bottom: 16px;
    }
    .fab-main {
      width: 50px;
      height: 50px;
    }
  }
</style>
